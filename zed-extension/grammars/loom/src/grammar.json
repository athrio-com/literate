{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "loom",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "heading"
          },
          {
            "type": "SYMBOL",
            "name": "code_block"
          },
          {
            "type": "SYMBOL",
            "name": "language_switch"
          },
          {
            "type": "SYMBOL",
            "name": "transclusion"
          },
          {
            "type": "SYMBOL",
            "name": "prose_block"
          },
          {
            "type": "SYMBOL",
            "name": "blank_line"
          }
        ]
      }
    },
    "heading": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "marker",
          "content": {
            "type": "SYMBOL",
            "name": "_heading_marker"
          }
        },
        {
          "type": "FIELD",
          "name": "text",
          "content": {
            "type": "SYMBOL",
            "name": "_heading_text"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "bracket",
              "content": {
                "type": "SYMBOL",
                "name": "heading_bracket"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_heading_eol"
        }
      ]
    },
    "_heading_marker": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 10,
        "content": {
          "type": "PATTERN",
          "value": "#{1,6}[ \\t]+"
        }
      }
    },
    "_heading_text": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^\\[\\n]*"
      }
    },
    "heading_bracket": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "["
          },
          {
            "type": "PATTERN",
            "value": "[^\\]\\n]*"
          },
          {
            "type": "STRING",
            "value": "]"
          },
          {
            "type": "PATTERN",
            "value": "[ \\t]*"
          }
        ]
      }
    },
    "_heading_eol": {
      "type": "PATTERN",
      "value": "\\n?"
    },
    "code_block": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "SYMBOL",
          "name": "code_line"
        }
      }
    },
    "code_line": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "PATTERN",
          "value": "[ \\t]+\\S[^\\n]*\\n?"
        }
      }
    },
    "language_switch": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 5,
        "content": {
          "type": "PATTERN",
          "value": "[ \\t]+\\[[a-zA-Z_]\\w*\\][ \\t]*\\n?"
        }
      }
    },
    "transclusion": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 5,
        "content": {
          "type": "PATTERN",
          "value": "[ \\t]+\\{\\{[^}\\n]+\\}\\}[ \\t]*\\n?"
        }
      }
    },
    "prose_block": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "SYMBOL",
          "name": "prose_line"
        }
      }
    },
    "prose_line": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "[^#\\s\\n][^\\n]*\\n?"
        }
      }
    },
    "blank_line": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 0,
        "content": {
          "type": "PATTERN",
          "value": "[ \\t]*\\n"
        }
      }
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}