{
  "name": "@literate/cli",
  "version": "0.1.0-alpha.1",
  "description": "Literate Framework CLI — the harness binding for Protocol.continue (ADR-014). Sole npm artefact under ADR-025; bundles its Trope logic and seed files from registry/ at build time per ADR-026.",
  "homepage": "https://github.com/athrio-com/literate",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/athrio-com/literate.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/athrio-com/literate/issues",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "(MIT OR Apache-2.0)",
  "type": "module",
  "main": "./dist/literate.js",
  "bin": {
    "literate": "dist/literate.js"
  },
  "exports": {
    ".": "./dist/literate.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "devDependencies": {
    "@effect/cli": "^0.75.1",
    "@effect/platform": "^0.96.1",
    "@effect/platform-bun": "^0.89.0",
    "@literate/core": "workspace:*",
    "@literate/template-minimal": "workspace:*",
    "@types/bun": "latest",
    "effect": "^3.21.0",
    "remark-mdx": "^3.0.1",
    "remark-parse": "^11.0.0",
    "typescript": "^5.6.0",
    "unified": "^11.0.5"
  }
}
