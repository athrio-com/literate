{
  "name": "@literate/monorepo",
  "version": "0.1.0",
  "description": "Literate Framework — prose-first, gated, AI-collaborative software authoring.",
  "private": true,
  "license": "(MIT OR Apache-2.0)",
  "workspaces": [
    "packages/*",
    "site"
  ],
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "cli": "bun run --cwd packages/cli start"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20"
  },
  "packageManager": "bun@1.1.0"
}
