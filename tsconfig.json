{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "noEmit": true,
    "paths": {
      "@literate/core": ["./src/core.ts"]
    }
  },
  "include": ["src", "corpus", "*.ts"],
  "exclude": ["src/from ai", "src/**/*.test.ts"]
}
